<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<VBox styleClass="form-page" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AddSaleController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <StackPane alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
        <VBox alignment="TOP_CENTER" maxWidth="900" spacing="20" styleClass="form-container">
            <padding>
                <Insets top="0" right="60" bottom="20" left="60" />
            </padding>

            <Label fx:id="formTitle" styleClass="title-text" text="Complete Purchase" />

            <GridPane hgap="30" vgap="15">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>

                <!-- Product Info (Read Only) -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label styleClass="form-label" text="Product Name" />
                    <TextField fx:id="productNameField" editable="false" styleClass="form-input" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label styleClass="form-label" text="Sale Reference" />
                    <TextField fx:id="referenceField" promptText="e.g. SALE-2024-001" styleClass="form-input" />
                </VBox>

                <!-- Amount & Currency -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label styleClass="form-label" text="Total Amount" />
                    <TextField fx:id="amountField" editable="false" styleClass="form-input" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label styleClass="form-label" text="Currency" />
                    <TextField fx:id="currencyField" editable="false" styleClass="form-input" />
                </VBox>

                <!-- Payment -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                    <Label styleClass="form-label" text="Payment Method" />
                    <ComboBox fx:id="paymentMethodCombo" maxWidth="Infinity" styleClass="form-input" />
                </VBox>

                <!-- Addresses -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label styleClass="form-label" text="Shipping Address" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="shippingField" promptText="Street address..." styleClass="form-input" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleOpenShippingMap" styleClass="secondary-btn" style="-fx-padding: 8;">
                            <graphic>
                                <FontIcon iconLiteral="fth-map-pin" iconSize="18" />
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label styleClass="form-label" text="Billing Address" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="billingField" promptText="Same as shipping..." styleClass="form-input" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleOpenBillingMap" styleClass="secondary-btn" style="-fx-padding: 8;">
                            <graphic>
                                <FontIcon iconLiteral="fth-map-pin" iconSize="18" />
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <!-- Notes -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2">
                    <Label styleClass="form-label" text="Additional Notes" />
                    <TextArea fx:id="notesField" prefHeight="80" promptText="Any special instructions..." styleClass="form-input, text-area" wrapText="true" />
                </VBox>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="form-actions">
                <Button onAction="#handleCancel" styleClass="secondary-btn" text="Cancel" />
                <Button fx:id="saveBtn" onAction="#handleSave" styleClass="primary-btn" text="Complete Sale" />
            </HBox>
        </VBox>
    </StackPane>
</VBox>
