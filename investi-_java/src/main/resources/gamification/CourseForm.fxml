<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.gamification.CourseController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent;">

<VBox styleClass="root-container"
      stylesheets="@coursesForm.css"
      spacing="0"
      minHeight="2200">

    <!-- Glass Header -->
    <HBox styleClass="glass-header" alignment="CENTER_LEFT" spacing="20" fx:id="headerBox">
        <padding>
            <Insets top="20" right="36" bottom="20" left="36"/>
        </padding>
        
        <Label text="Course Management" styleClass="page-title" HBox.hgrow="ALWAYS" fx:id="titleLabel"/>
        
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="exportCoursesBtn" text="📊 Export Courses" onAction="#handleExportCourses"
                    styleClass="btn, btn-success"/>
            <Button fx:id="exportAnalyticsBtn" text="📈 Export Analytics" onAction="#handleExportAnalytics"
                    styleClass="btn, btn-success"/>
            <Button fx:id="viewReportsBtn" text="📋 View Reports" onAction="#handleViewReports"
                    styleClass="btn, btn-warning"/>
            <Button fx:id="themeToggleBtn" text="🌙 Dark" onAction="#handleThemeToggle"
                    styleClass="btn, btn-secondary, theme-btn"/>
            <Button fx:id="autoModeBtn" text="⏰ Auto" onAction="#handleAutoMode"
                    styleClass="btn, btn-secondary, auto-btn"/>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <VBox spacing="32" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="32" right="36" bottom="32" left="36"/>
        </padding>

    <!-- Form Fields -->
    <VBox spacing="20" fx:id="formContainer" styleClass="form-container">
    <GridPane styleClass="form-grid">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="140"/>
            <ColumnConstraints minWidth="300" prefWidth="420" hgrow="ALWAYS"/>
        </columnConstraints>

        <!-- Title -->
        <Label text="Title:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="titleField" promptText="Enter course title" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Slug -->
        <Label text="Slug:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="slugField" promptText="course-slug" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <!-- Description -->
        <Label text="Description:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextArea fx:id="descriptionArea" promptText="Enter course description" 
                  prefRowCount="3" styleClass="modern-text-area"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Content URL -->
        <Label text="Content URL:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <TextField fx:id="contentUrlField" promptText="https://example.com/course or local file path" 
                       styleClass="modern-text-field" HBox.hgrow="ALWAYS"/>
            <Button text="📁 Browse" onAction="#handleBrowseFile" 
                    styleClass="btn, btn-secondary" 
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
        </HBox>

        <!-- Content Type -->
        <Label text="Content Type:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <ComboBox fx:id="contentTypeCombo" promptText="Select type" styleClass="modern-combo"
                  GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="200"/>

        <!-- Difficulty Level -->
        <Label text="Difficulty:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="difficultyCombo" promptText="Select difficulty" styleClass="modern-combo"
                  GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="200"/>

        <!-- Category -->
        <Label text="Category:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="categoryField" promptText="programming, database, web..." styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <!-- Language -->
        <Label text="Language:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="languageField" promptText="en, fr, ar..." styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <!-- Duration -->
        <Label text="Duration (min):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <TextField fx:id="durationField" promptText="120" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="8"/>

        <!-- Reward Points -->
        <Label text="Reward Points:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
        <TextField fx:id="rewardPointsField" promptText="100" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="9"/>

        <!-- Minimum Points Required -->
        <Label text="Min Points Required:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
        <TextField fx:id="minimumPointsField" promptText="0 (unlocked) or points needed" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="10"/>

        <!-- Thumbnail URL -->
        <Label text="Thumbnail URL:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="11"/>
        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="11">
            <TextField fx:id="thumbnailField" promptText="https://example.com/image.jpg or local file path" 
                       styleClass="modern-text-field" HBox.hgrow="ALWAYS"/>
            <Button text="🖼️ Browse" onAction="#handleBrowseThumbnail" 
                    styleClass="btn, btn-secondary" 
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
        </HBox>
    </GridPane>
    </VBox>

    <Separator styleClass="styled-separator"/>

    <!-- Buttons -->
    <HBox styleClass="button-bar" fx:id="buttonBar">
        <Button text="Add Course" onAction="#handleAddCourse" 
                styleClass="btn, btn-primary" prefWidth="130"/>
        <Button text="Clear Form" onAction="#handleClearForm" 
                styleClass="btn, btn-secondary" prefWidth="130"/>
        <Button text="Statistics" onAction="#handleStatistics" 
                styleClass="btn, btn-secondary" prefWidth="130" style="-fx-background-color: #9B7E46;"/>
        <Button text="View All" onAction="#handleViewAll" 
                styleClass="btn, btn-secondary" prefWidth="130"/>
        <Button text="Back" onAction="#handleBack" 
                styleClass="btn, btn-dark" prefWidth="110"/>
    </HBox>

    <!-- Status Label -->
    <HBox alignment="CENTER" fx:id="statusContainer" managed="false" visible="false">
        <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>
    </HBox>

    <!-- Animated Separator -->
    <StackPane prefHeight="2" maxHeight="2" fx:id="separatorPane">
       
        <Rectangle styleClass="shimmer-line" height="1" width="${separatorPane.width}" fx:id="shimmerLine"/>
    </StackPane>

    <!-- Course List -->
    <VBox spacing="12" VBox.vgrow="ALWAYS" fx:id="courseListSection" managed="false" visible="false">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="✨" style="-fx-font-size: 18px;" styleClass="sparkle-icon" fx:id="sparkleIcon"/>
            <Label text="Existing Courses" styleClass="section-title"/>
            <Label fx:id="courseCountLabel" text="(0)" styleClass="badge-count"/>
            <Region HBox.hgrow="ALWAYS"/>

        </HBox>

        <!-- Search and Sort Controls -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search by title, category, or difficulty..."
                       styleClass="modern-text-field"
                       prefWidth="350" HBox.hgrow="ALWAYS"/>
            
            <ComboBox fx:id="sortCombo" promptText="Sort by..."
                      styleClass="modern-combo"
                      prefWidth="200"/>
            
            <Button text="Clear" onAction="#handleClearSearch"
                    styleClass="btn, btn-secondary"
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
        </HBox>

        <ScrollPane fitToWidth="true" minHeight="600" prefHeight="700" VBox.vgrow="ALWAYS"
                    styleClass="item-scroll-pane">
            <VBox fx:id="courseListContainer" styleClass="item-list-container">
                <!-- Courses will be loaded here dynamically -->
            </VBox>
        </ScrollPane>
    </VBox>
    </VBox>

</VBox>

</ScrollPane>
