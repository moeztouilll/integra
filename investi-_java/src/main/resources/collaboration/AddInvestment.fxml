<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<AnchorPane stylesheets="@Project.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a8.controllers.collaboration.investment.AddInvestmentController">
    <children>
        <VBox alignment="CENTER" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <VBox spacing="15" styleClass="form-container">
                <Label text="Add Investment" styleClass="heading"/>

                <VBox spacing="4">
                    <Label text="Project ID" style="-fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <TextField fx:id="projectTf" promptText="Enter Project ID"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Total Amount" style="-fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <TextField fx:id="amountTf" promptText="0.00"/>
                </VBox>
                
                <VBox spacing="4">
                    <Label text="Duration (Months)" style="-fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <TextField fx:id="durationTf" promptText="e.g. 12"/>
                </VBox>
                
                <VBox spacing="4">
                    <Label text="Equity %" style="-fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                    <TextField fx:id="equityTf" promptText="e.g. 10.0"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Back" onAction="#goMain" styleClass="secondary"/>
                    <Button text="Save" onAction="#saveInvestment"/>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
