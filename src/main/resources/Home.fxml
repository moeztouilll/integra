<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.connexion3a8.controllers.HomeController"
            style="-fx-background-color: #000501;" stylesheets="@styles.css">
    
    <!-- Modern Header with Glass Effect -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 3);">
            <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                <Image url="@INVESTI.png"/>
            </ImageView>
            <Label text="INVESTI" styleClass="header-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📚 Courses" onAction="#handleCourses" styleClass="modern-button, button-primary"/>
            <Button text="📅 Events" onAction="#handleEvents" styleClass="modern-button, button-primary"/>
            <Button text="💬 Forum" onAction="#handleForum" styleClass="modern-button, button-primary"/>
            <Button text="🤝 Collaboration" onAction="#handleCollaboration" styleClass="modern-button, button-primary"/>
            <Button fx:id="adminDashboardBtn" text="⚙ Dashboard" onAction="#handleAdminDashboard" visible="false" managed="false"
                  styleClass="modern-button, button-secondary"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="modern-button, button-danger"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #000501; -fx-background-color: #000501;" styleClass="scroll-pane">
            <VBox spacing="60" style="-fx-background-color: #000501;">
                <padding>
                    <Insets top="40" right="60" bottom="60" left="60"/>
                </padding>
                
                <!-- KYC Banner (shown when is_active=false) -->
                <HBox fx:id="kycBanner" alignment="CENTER" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: #9B7E46; -fx-background-radius: 12; -fx-padding: 18 30;">
                    <Label text="⚠ Your account is pending verification. Please upload your ID to use all features."
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="uploadIdBtn" text="📤 Upload ID" onAction="#handleUploadId"
                            style="-fx-background-color: white; -fx-text-fill: #9B7E46; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
                </HBox>
                
                <!-- KYC Pending Review Banner -->
                <HBox fx:id="kycPendingBanner" alignment="CENTER" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: #456990; -fx-background-radius: 12; -fx-padding: 18 30;">
                    <Label text="⏳ Your ID has been submitted and is under review. You will be notified once approved."
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Hero Section -->
                <VBox alignment="CENTER" spacing="25" style="-fx-background-color: #000501;">
                    <Label text="Where Innovation Meets Investment" styleClass="title-large" wrapText="true" textAlignment="CENTER"/>
                    <Label text="Connect with visionary innovators and strategic investors. Transform groundbreaking ideas into successful ventures."
                         styleClass="subtitle" style="-fx-max-width: 700; -fx-text-alignment: center;" wrapText="true" textAlignment="CENTER"/>
                </VBox>
                
                <!-- Stats Section with Modern Cards -->
                <HBox alignment="CENTER" spacing="30" styleClass="stats-card">
                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="500+" styleClass="stat-number"/>
                        <Label text="Active Users" styleClass="stat-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: rgba(247,240,245,0.3);"/>
                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="200+" styleClass="stat-number"/>
                        <Label text="Ideas Shared" styleClass="stat-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: rgba(247,240,245,0.3);"/>
                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="150+" styleClass="stat-number"/>
                        <Label text="Projects Funded" styleClass="stat-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: rgba(247,240,245,0.3);"/>
                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                        <Label text="300+" styleClass="stat-number"/>
                        <Label text="Collaborations" styleClass="stat-label"/>
                    </VBox>
                </HBox>
                
                <!-- How It Works Section -->
                <VBox spacing="30" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="10">
                        <Label text="How It Works" styleClass="title-medium" style="-fx-text-fill: white;"/>
                        <Label text="Your journey from idea to funded project in four simple steps"
                             style="-fx-font-size: 15px; -fx-text-fill: #F7F0F5;"/>
                    </VBox>
                    
                    <GridPane hgap="30" vgap="30" alignment="CENTER">
                        <!-- Step 1 -->
                        <VBox spacing="15" styleClass="step-card" GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="280">
                            <Label text="1" styleClass="step-number"/>
                            <Label text="Share Your Idea" styleClass="step-title"/>
                            <Label text="Post your innovative concept and get feedback from the community" 
                                 styleClass="step-description" wrapText="true"/>
                        </VBox>
                        
                        <!-- Step 2 -->
                        <VBox spacing="15" styleClass="step-card" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="280">
                            <Label text="2" styleClass="step-number"/>
                            <Label text="Connect" styleClass="step-title"/>
                            <Label text="Find investors and collaborators who share your vision"
                                 styleClass="step-description" wrapText="true"/>
                        </VBox>
                        
                        <!-- Step 3 -->
                        <VBox spacing="15" styleClass="step-card" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="280">
                            <Label text="3" styleClass="step-number"/>
                            <Label text="Collaborate" styleClass="step-title"/>
                            <Label text="Work together to refine and develop your project"
                                 styleClass="step-description" wrapText="true"/>
                        </VBox>
                        
                        <!-- Step 4 -->
                        <VBox spacing="15" styleClass="step-card" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="280">
                            <Label text="4" styleClass="step-number"/>
                            <Label text="Launch" styleClass="step-title"/>
                            <Label text="Bring your idea to life with funding and support"
                                 styleClass="step-description" wrapText="true"/>
                        </VBox>
                    </GridPane>
                </VBox>
                
                <!-- CTA Section -->
                <VBox alignment="CENTER" spacing="20" styleClass="cta-section">
                    <Label text="Ready to Start Your Journey?" styleClass="cta-title" textAlignment="CENTER"/>
                    <Label text="Join thousands of innovators and investors transforming ideas into reality."
                         styleClass="cta-text" textAlignment="CENTER"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
