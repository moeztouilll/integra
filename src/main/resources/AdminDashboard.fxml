<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.connexion3a8.controllers.AdminDashboardController"
            style="-fx-background-color: #F7F0F5;" stylesheets="@styles.css">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 3);">
            <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                <Image url="@INVESTI.png"/>
            </ImageView>
            <Label text="INVESTI - Admin Dashboard" styleClass="header-logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🎮 Gamification" onAction="#handleGamification" styleClass="modern-button, button-secondary"/>
            <Button text="📅 Events" onAction="#handleEventManagement" styleClass="modern-button, button-secondary"/>
            <Button text="🤝 Collaboration" onAction="#handleViewCollaboration" styleClass="modern-button, button-secondary"/>
            <Button text="👥 Users" onAction="#handleUserManagement" styleClass="modern-button, button-secondary"/>
            <Button text="🛍️ Products" onAction="#handleProducts" styleClass="modern-button, button-secondary"/>
            <Button text="🏠 Home" onAction="#handleViewHome" styleClass="modern-button, button-primary"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="modern-button, button-danger"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-background: #F7F0F5; -fx-background-color: #F7F0F5;">
            <VBox spacing="25" style="-fx-background-color: #F7F0F5;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Stats Bar -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #456990; -fx-background-radius: 12; -fx-padding: 20;">
                        <Label fx:id="statTotal" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Total Users" style="-fx-font-size: 12px; -fx-text-fill: #F7F0F5;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #2E7D32; -fx-background-radius: 12; -fx-padding: 20;">
                        <Label fx:id="statVerified" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Verified (Active)" style="-fx-font-size: 12px; -fx-text-fill: #E8F5E9;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #9B7E46; -fx-background-radius: 12; -fx-padding: 20;">
                        <Label fx:id="statPending" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Pending KYC" style="-fx-font-size: 12px; -fx-text-fill: #FFF8E1;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #A62639; -fx-background-radius: 12; -fx-padding: 20;">
                        <Label fx:id="statUnverified" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Unverified" style="-fx-font-size: 12px; -fx-text-fill: #FFEBEE;"/>
                    </VBox>
                </HBox>

                <!-- KYC Review Section -->
                <VBox spacing="15" styleClass="modern-card">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="🔍 KYC Verification Queue" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000501;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🔄 Refresh" onAction="#refreshKycTable" styleClass="modern-button, button-secondary"/>
                    </HBox>

                    <Label fx:id="kycEmptyLabel" text="✓ No pending KYC requests"
                           style="-fx-font-size: 14px; -fx-text-fill: #456990; -fx-padding: 20; -fx-alignment: center;"
                           visible="false" managed="false"/>

                    <TableView fx:id="kycTable" styleClass="table-view" prefHeight="220" minHeight="180">
                        <columns>
                            <TableColumn fx:id="kycColName" text="Name" prefWidth="150" minWidth="120"/>
                            <TableColumn fx:id="kycColEmail" text="Email" prefWidth="220" minWidth="150"/>
                            <TableColumn fx:id="kycColRole" text="Role" prefWidth="120" minWidth="80"/>
                            <TableColumn fx:id="kycColActions" text="Actions" prefWidth="320" minWidth="280"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Add/Edit User Form -->
                <VBox spacing="20" styleClass="modern-card">
                    <Label text="Add / Edit User" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000501;"/>

                    <GridPane hgap="20" vgap="15">
                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="label-field"/>
                        <TextField fx:id="emailField" promptText="user@example.com" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   styleClass="modern-input" GridPane.hgrow="ALWAYS"/>

                        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="label-field"/>
                        <TextField fx:id="nameField" promptText="Full Name" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   styleClass="modern-input" GridPane.hgrow="ALWAYS"/>

                        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="label-field"/>
                        <PasswordField fx:id="passwordField" promptText="Password" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                       styleClass="modern-input" GridPane.hgrow="ALWAYS"/>

                        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="label-field"/>
                        <TextField fx:id="roleField" promptText="user, innovator, investor, admin" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                   styleClass="modern-input" GridPane.hgrow="ALWAYS"/>

                        <Label text="Bio:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="label-field" GridPane.valignment="TOP"/>
                        <TextArea fx:id="bioField" promptText="User bio (optional)" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                  styleClass="modern-input" GridPane.hgrow="ALWAYS" prefRowCount="3" wrapText="true"/>
                    </GridPane>

                    <HBox spacing="15">
                        <Button fx:id="btnAdd" text="💾 Save User" onAction="#addUser" styleClass="modern-button, button-primary"/>
                        <Button fx:id="btnClear" text="✕ Clear" onAction="#handleClear" styleClass="modern-button"
                                style="-fx-background-color: #E8E8E8; -fx-text-fill: #333;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRefresh" text="🔄 Refresh" onAction="#refreshTable" styleClass="modern-button, button-secondary"/>
                    </HBox>
                </VBox>

                <!-- Users Table -->
                <VBox spacing="15" styleClass="modern-card" style="-fx-min-height: 600;">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="All Users" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000501;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefWidth="30" prefHeight="30"/>
                    </HBox>

                    <!-- Search + Filter Row -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="🔍 Search by name, email, or role..." styleClass="modern-input" HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="filterCombo" promptText="Filter by status"
                                  style="-fx-background-color: #F7F0F5; -fx-background-radius: 10; -fx-padding: 10; -fx-font-size: 13px; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-border-width: 1; -fx-pref-width: 200;"/>
                    </HBox>

                    <Label fx:id="emptyStateLabel" text="📭 No users found."
                           style="-fx-font-size: 16px; -fx-text-fill: #666; -fx-padding: 40; -fx-alignment: center;"
                           visible="false" managed="false"/>

                    <!-- User count label -->
                    <Label fx:id="userCountLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>

                    <TableView fx:id="userTable" styleClass="table-view" prefHeight="500" minHeight="500">
                        <columns>
                            <TableColumn fx:id="colName" text="Name" prefWidth="160" minWidth="120"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="220" minWidth="150"/>
                            <TableColumn fx:id="colRole" text="Role" prefWidth="100" minWidth="80"/>
                            <TableColumn fx:id="colStatus" text="Status" prefWidth="120" minWidth="100"/>
                            <TableColumn fx:id="colPoints" text="Points" prefWidth="80" minWidth="60"/>
                            <TableColumn fx:id="colLevel" text="Level" prefWidth="70" minWidth="50"/>
                            <TableColumn fx:id="colCreatedAt" text="Joined" prefWidth="140" minWidth="120"/>
                            <TableColumn fx:id="colActions" text="Actions" prefWidth="300" minWidth="260"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
