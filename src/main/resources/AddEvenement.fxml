<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.connexion3a8.controllers.events.AddEvenementController"
            stylesheets="@css/style.css"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <Label text="📝 Événement" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label text="Ajouter ou modifier un événement" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: white; -fx-max-width: 550;">
    
                <Label text="Titre *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                <TextField fx:id="titre" promptText="Ex: Formation JavaFX"/>
    
                <Label text="Contenu *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                <TextField fx:id="contenu" promptText="Description de l'événement"/>
    
                <Label text="Lieu *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                <TextField fx:id="lieu" promptText="Ex: ESPRIT Tunis"/>
                <Label fx:id="lblGeoStatus" text="" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
    
                <VBox spacing="5" style="-fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 4;">
                    <WebView fx:id="mapWebView" prefHeight="250.0" minHeight="200.0"/>
                </VBox>
    
                <Label text="ID Mentor *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                <ComboBox fx:id="id_mentor" prefWidth="200"/>
    
                <HBox spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Date Début *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                        <DatePicker fx:id="date_deb"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Date Fin *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
                        <DatePicker fx:id="date_fin"/>
                    </VBox>
                </HBox>
    
                <Separator style="-fx-padding: 10 0;"/>
    
                <VBox spacing="8">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="btnGenerateImage" text="🎨 Générer Image" onAction="#generateImage"
                                styleClass="btn-secondary" prefWidth="180"/>
                        <Label fx:id="lblImageStatus" text="" style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    </HBox>
                    <Label text="Générez une image promotionnelle pour cet événement" 
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;"/>
                    
                    <!-- Image Preview -->
                    <VBox fx:id="imagePreviewContainer" spacing="5" visible="false" managed="false"
                          style="-fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 8; -fx-padding: 10; -fx-background-color: #F8FAFC; -fx-background-radius: 8;">
                        <Label text="Aperçu de l'image générée:" style="-fx-font-weight: 600; -fx-font-size: 12px;"/>
                        <javafx.scene.image.ImageView fx:id="imagePreview" fitWidth="500" fitHeight="300" preserveRatio="true"
                                                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);"/>
                    </VBox>
                </VBox>
    
                <Separator style="-fx-padding: 10 0;"/>
    
                <HBox spacing="12" alignment="CENTER">
                    <Button fx:id="btnAction" text="➕ Ajouter" onAction="#add_evenement"
                            styleClass="btn-primary" prefWidth="150"/>
                    <Button fx:id="btnAnnuler" text="❌ Annuler" onAction="#annuler"
                            styleClass="btn-secondary" prefWidth="150"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
