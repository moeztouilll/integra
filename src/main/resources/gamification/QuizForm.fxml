<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.gamification.QuizController"
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent;">

<VBox styleClass="root-container"
      stylesheets="@coursesForm.css"
      spacing="20"
      minHeight="1800">

    <padding>
        <Insets top="32" right="36" bottom="32" left="36"/>
    </padding>

    <!-- Title and Theme Toggle -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Quiz Management" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button fx:id="themeToggleBtn" text="🌙 Dark" onAction="#handleThemeToggle"
                    styleClass="btn, btn-secondary"
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
            <Button fx:id="autoModeBtn" text="⏰ Auto" onAction="#handleAutoMode"
                    styleClass="btn, btn-secondary"
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
        </HBox>
    </HBox>

    <Separator styleClass="styled-separator"/>

    <!-- Form Fields -->
    <GridPane styleClass="form-grid">
        <columnConstraints>
            <ColumnConstraints minWidth="150" prefWidth="160"/>
            <ColumnConstraints minWidth="300" prefWidth="420" hgrow="ALWAYS"/>
        </columnConstraints>

        <!-- Title -->
        <Label text="Title:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="titleField" promptText="Enter quiz title" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Description -->
        <Label text="Description:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextArea fx:id="descriptionArea" promptText="Enter quiz description" 
                  prefRowCount="3" styleClass="modern-text-area"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <!-- Points Reward -->
        <Label text="Points Reward:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="pointsRewardField" promptText="100" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Difficulty Level -->
        <Label text="Difficulty:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="difficultyCombo" promptText="Select difficulty" styleClass="modern-combo"
                  GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="200"/>

        <!-- Category -->
        <Label text="Category:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="categoryField" promptText="programming, database, web..." styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <!-- Related Course -->
        <Label text="Related Course:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="courseCombo" promptText="Select course (optional)" styleClass="modern-combo"
                  GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="400"/>

        <!-- Time Limit -->
        <Label text="Time Limit (sec):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="timeLimitField" promptText="600" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <!-- Passing Score -->
        <Label text="Passing Score (%):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="passingScoreField" promptText="70" styleClass="modern-text-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <!-- Status -->
        <Label text="Status:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <ComboBox fx:id="statusCombo" promptText="Select status" styleClass="modern-combo"
                  GridPane.columnIndex="1" GridPane.rowIndex="8" prefWidth="200"/>
    </GridPane>

    <Separator styleClass="styled-separator"/>

    <!-- Buttons -->
    <HBox styleClass="button-bar">
        <Button text="Add Quiz" onAction="#handleAddQuiz" 
                styleClass="btn, btn-primary" prefWidth="130"/>
        <Button text="Clear Form" onAction="#handleClearForm" 
                styleClass="btn, btn-secondary" prefWidth="130"/>
        <Button fx:id="manageQuestionsBtn" text="Manage Questions" onAction="#handleManageQuestions" 
                styleClass="btn, btn-secondary" prefWidth="160" disable="true"/>
        <Button text="Statistics" onAction="#handleStatistics" 
                styleClass="btn, btn-secondary" prefWidth="130" style="-fx-background-color: #9B7E46;"/>
        <Button text="View All" onAction="#handleViewAll" 
                styleClass="btn, btn-secondary" prefWidth="130"/>
        <Button text="Back" onAction="#handleBack" 
                styleClass="btn, btn-dark" prefWidth="110"/>
    </HBox>

    <!-- Status Label -->
    <Label fx:id="statusLabel" styleClass="status-label"
           alignment="CENTER" wrapText="true"/>

    <Separator styleClass="styled-separator"/>

    <!-- Quiz List -->
    <VBox spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Existing Quizzes" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="📝" style="-fx-font-size: 16px;"/>
        </HBox>

        <!-- Search and Sort Controls -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search by title, category, difficulty, or points..."
                       styleClass="modern-text-field"
                       prefWidth="380" HBox.hgrow="ALWAYS"/>
            
            <ComboBox fx:id="sortCombo" promptText="Sort by..."
                      styleClass="modern-combo"
                      prefWidth="220"/>
            
            <Button text="Clear" onAction="#handleClearSearch"
                    styleClass="btn, btn-secondary"
                    style="-fx-font-size: 12px; -fx-padding: 8 16 8 16;"/>
        </HBox>

        <ScrollPane fitToWidth="true" minHeight="600" prefHeight="700" VBox.vgrow="ALWAYS"
                    styleClass="item-scroll-pane">
            <VBox fx:id="quizListContainer" styleClass="item-list-container">
                <!-- Quizzes will be loaded here dynamically -->
            </VBox>
        </ScrollPane>
    </VBox>

</VBox>

</ScrollPane>
