<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.gamification.BadgeController"
            fitToWidth="true"
            style="-fx-background-color: transparent;"
            fx:id="mainScrollPane">

<VBox styleClass="root-container"
      stylesheets="@badgesFormRedesign.css"
      spacing="0"
      minHeight="1500"
      fx:id="mainContainer">

    <!-- Glass Header -->
    <HBox styleClass="glass-header" alignment="CENTER_LEFT" spacing="20" fx:id="headerBox">
        <padding>
            <Insets top="20" right="36" bottom="20" left="36"/>
        </padding>
        
        <Label text="Badge Management" styleClass="page-title" HBox.hgrow="ALWAYS" fx:id="titleLabel"/>
        
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="themeToggleBtn" text="🌙 Dark" onAction="#handleThemeToggle"
                    styleClass="btn, btn-secondary, theme-btn"/>
            <Button fx:id="autoModeBtn" text="⏰ Auto" onAction="#handleAutoMode"
                    styleClass="btn, btn-secondary, auto-btn"/>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <VBox spacing="32" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="32" right="36" bottom="32" left="36"/>
        </padding>

        <!-- Form Section -->
        <VBox styleClass="form-container" spacing="0" fx:id="formContainer">
            <GridPane styleClass="form-grid" hgap="16" vgap="16">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="130" percentWidth="20"/>
                    <ColumnConstraints minWidth="200" hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- Badge Name -->
                <Label text="Badge Name:" styleClass="form-label" 
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="nameField" promptText="Enter badge name" 
                          styleClass="modern-text-field"
                          GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <!-- Description -->
                <Label text="Description:" styleClass="form-label" 
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextArea fx:id="descriptionArea" promptText="Enter badge description" 
                         prefRowCount="3" prefHeight="70" styleClass="modern-text-area"
                         GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <!-- Points Required -->
                <Label text="Points Required:" styleClass="form-label" 
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <TextField fx:id="pointsRequiredField" promptText="0" 
                              styleClass="modern-text-field" maxWidth="200"/>
                    <Label text="💡 Set to 0 for badges earned by actions (not points)" 
                           styleClass="hint-label" wrapText="true"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- Action Buttons -->
        <HBox styleClass="button-bar" spacing="16" alignment="CENTER" fx:id="buttonBar">
            <Button text="➕ Add Badge" onAction="#handleAddBadge" 
                    styleClass="btn, btn-primary, action-btn" prefWidth="140" fx:id="addBtn"/>
            <Button text="🗑️ Clear Form" onAction="#handleClearForm"
                    styleClass="btn, btn-secondary, action-btn" prefWidth="140" fx:id="clearBtn"/>
            <Button text="📊 Statistics" onAction="#handleStatistics"
                    styleClass="btn, btn-secondary, action-btn" prefWidth="140" style="-fx-background-color: #9B7E46;"/>
            <Button text="👁️ View All" onAction="#handleViewAll"
                    styleClass="btn, btn-secondary, action-btn" prefWidth="140" fx:id="viewBtn"/>
            <Button text="← Back" onAction="#handleBack" 
                    styleClass="btn, btn-dark, action-btn" prefWidth="120" fx:id="backBtn"/>
        </HBox>

        <!-- Status Label -->
        <HBox alignment="CENTER" fx:id="statusContainer" managed="false" visible="false">
            <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>
        </HBox>

        <!-- Animated Separator -->
        <StackPane prefHeight="2" maxHeight="2" fx:id="separatorPane">

            <Rectangle styleClass="shimmer-line" height="3" width="${separatorPane.width}" fx:id="shimmerLine"/>
        </StackPane>

        <!-- Badge List Section (Hidden by default) -->
        <VBox spacing="20" VBox.vgrow="ALWAYS" fx:id="badgeListSection" managed="false" visible="false">
            <!-- Section Header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="✨" style="-fx-font-size: 18px;" styleClass="sparkle-icon" fx:id="sparkleIcon"/>
                <Label text="Existing Badges" styleClass="section-title"/>
                <Label fx:id="badgeCountLabel" text="(0)" styleClass="badge-count"/>
            </HBox>

            <!-- Search and Sort Controls -->
            <HBox spacing="12" alignment="CENTER_LEFT" fx:id="searchSortBox">
                <TextField fx:id="searchField" promptText="🔍 Search by name or points..." 
                          styleClass="modern-text-field" HBox.hgrow="ALWAYS"/>
                
                <ComboBox fx:id="sortCombo" promptText="Sort by..." 
                         styleClass="modern-combo" minWidth="160"/>
                
                <Button text="✕ Clear" onAction="#handleClearSearch"
                       styleClass="btn, btn-secondary" 
                       style="-fx-font-size: 11px; -fx-padding: 6 14 6 14;"/>
            </HBox>

            <!-- Badge Cards Container -->
            <ScrollPane fitToWidth="true" minHeight="800" prefHeight="700" maxHeight="700"
                       styleClass="badge-scroll-pane" VBox.vgrow="NEVER" fx:id="badgeScrollPane">
                <VBox fx:id="badgeListContainer" styleClass="badge-list-container" spacing="10">
                    <!-- Badges will be loaded here dynamically -->
                </VBox>
            </ScrollPane>
        </VBox>
    </VBox>

</VBox>

</ScrollPane>
