<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.gamification.QuizTakingController"
            fitToWidth="true"
            styleClass="scroll-pane"
            stylesheets="@quizTaking.css">

    <VBox styleClass="root-container" spacing="25" alignment="TOP_CENTER">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <!-- Header with Quiz Info and Timer -->
        <HBox styleClass="glass-header" alignment="CENTER_LEFT" spacing="20">
            <VBox.margin>
                <Insets bottom="10"/>
            </VBox.margin>
            
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="quizTitleLabel" styleClass="page-title" text="Quiz Title"/>
                <Label fx:id="quizInfoLabel" styleClass="quiz-info" text="10 questions • 100 points"/>
            </VBox>
            
            <!-- Timer Display -->
            <VBox alignment="CENTER" spacing="5" styleClass="timer-container">
                <Label text="⏱️ Time Remaining" styleClass="timer-label"/>
                <Label fx:id="timerLabel" styleClass="timer-display" text="10:00"/>
            </VBox>
            
            <!-- Night Mode Toggle -->
            <Button fx:id="nightModeToggle" text="🌙 Night Mode" onAction="#toggleNightMode" styleClass="btn, btn-dark"/>
        </HBox>

        <!-- Progress Bar Section -->
        <VBox spacing="10" styleClass="progress-section">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="progressLabel" styleClass="progress-label" text="Question 1 of 10"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="scoreLabel" styleClass="score-label" text="Score: 0/0"/>
            </HBox>
            <ProgressBar fx:id="progressBar" prefWidth="Infinity" progress="0.1" styleClass="quiz-progress-bar"/>
        </VBox>

        <!-- Question Card -->
        <VBox styleClass="question-card" spacing="20">
            <VBox spacing="10">
                <Label fx:id="questionNumberLabel" styleClass="question-number" text="Question 1"/>
                <Label fx:id="questionTextLabel" styleClass="question-text" wrapText="true" 
                       text="What is the capital of France?"/>
            </VBox>

            <Separator styleClass="styled-separator"/>

            <!-- Options Container -->
            <VBox fx:id="optionsContainer" spacing="12"/>
        </VBox>

        <!-- Navigation Buttons -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="previousBtn" text="⬅️ Previous" onAction="#handlePrevious" 
                    styleClass="btn, btn-secondary" prefWidth="150" disable="true"/>
            <Button fx:id="nextBtn" text="Next ➡️" onAction="#handleNext" 
                    styleClass="btn, btn-primary" prefWidth="150"/>
            <Button fx:id="submitBtn" text="✅ Submit Quiz" onAction="#handleSubmit" 
                    styleClass="btn, btn-success" prefWidth="150" visible="false"/>
        </HBox>

        <!-- Back Button -->
        <Button text="🔙 Back to Course" onAction="#handleBack" styleClass="btn, btn-dark" prefWidth="200"/>
    </VBox>
</ScrollPane>
