<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      spacing="20" alignment="CENTER" style="-fx-background-color: #000501;">
    
    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>
    
    <!-- Title -->
    <Label text="Gamification System" 
           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #F7F0F5;"/>
    
    <Label text="Management Dashboard" 
           style="-fx-font-size: 18px; -fx-text-fill: #F7F0F5;"/>
    
    <Region VBox.vgrow="ALWAYS" minHeight="30"/>
    
    <!-- Menu Buttons -->
    <VBox spacing="15" alignment="CENTER" maxWidth="300">
        <Button fx:id="browseCatalogBtn" text="📚 Browse Course Catalog" 
                style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-font-weight: bold;"
                prefWidth="280"/>
        
        <Separator style="-fx-background-color: #F7F0F5; -fx-opacity: 0.3;" prefWidth="280"/>
        
        <Button fx:id="coursesBtn" text="📚 Manage Courses" 
                style="-fx-background-color: #456990; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px; -fx-cursor: hand;"
                prefWidth="280"/>
        
        <Button fx:id="quizzesBtn" text="📝 Manage Quizzes" 
                style="-fx-background-color: #456990; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px; -fx-cursor: hand;"
                prefWidth="280"/>
        
        <Button fx:id="badgesBtn" text="🏆 Manage Badges" 
                style="-fx-background-color: #9B7E46; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px; -fx-cursor: hand;"
                prefWidth="280"/>
        
        <Button fx:id="usersBtn" text="👥 View Users" 
                style="-fx-background-color: #A62639; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 15px; -fx-background-radius: 8px; -fx-cursor: hand;"
                prefWidth="280"/>
    </VBox>
    
    <Region VBox.vgrow="ALWAYS" minHeight="30"/>
    
    <Label text="© 2024 Gamification System - 3A8" 
           style="-fx-text-fill: #F7F0F5; -fx-font-size: 12px; -fx-opacity: 0.8;"/>
    
</VBox>
