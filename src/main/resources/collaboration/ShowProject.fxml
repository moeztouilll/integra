<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane stylesheets="@Project.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a8.controllers.collaboration.Project.ShowProjectController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label text="Projects List" styleClass="heading">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <HBox HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#goAdd" text="Add Project" />
                  <Button mnemonicParsing="false" onAction="#goMain" styleClass="secondary" text="Back to Menu" />
               </children>
            </HBox>
            <TableView fx:id="projectTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="idCol" text="ID" />
                <TableColumn fx:id="titleCol" text="Title" />
                  <TableColumn fx:id="descCol" text="Description" />
                  <TableColumn fx:id="amountCol" text="Amount" />
                  <TableColumn fx:id="equityCol" text="Equity %" />
                  <TableColumn fx:id="statusCol" text="Status" />
                  <TableColumn fx:id="actionCol" text="Action" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
