<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane stylesheets="@Project.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a8.controllers.collaboration.investment.UpdateInvestmentController">
    <children>
        <VBox alignment="CENTER" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <VBox spacing="15" styleClass="form-container">
                <Label text="Update Investment" styleClass="heading"/>

                <StackPane styleClass="float-label-wrapper" style="-fx-opacity: 0.8;">
                    <TextField fx:id="idTf" promptText=""/>
                    <Label text="Investment ID" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>

                <StackPane styleClass="float-label-wrapper">
                    <TextField fx:id="projectTf" promptText=""/>
                    <Label text="Project ID" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>
                <StackPane styleClass="float-label-wrapper">
                    <TextField fx:id="investorTf" promptText=""/>
                    <Label text="Investor ID" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>
                <StackPane styleClass="float-label-wrapper">
                    <TextField fx:id="amountTf" promptText=""/>
                    <Label text="Total Amount" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>
                <StackPane styleClass="float-label-wrapper">
                    <TextField fx:id="durationTf" promptText=""/>
                    <Label text="Duration (months)" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>
                <StackPane styleClass="float-label-wrapper">
                    <TextField fx:id="equityTf" promptText=""/>
                    <Label text="Equity (%)" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>
                <StackPane styleClass="float-label-wrapper" style="-fx-opacity: 0.8;">
                    <TextField fx:id="statusTf" promptText=""/>
                    <Label text="Status (PENDING, ACCEPTED, REFUSED)" styleClass="float-label" mouseTransparent="true"/>
                </StackPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button onAction="#goMain" styleClass="secondary" text="Back" />
                    <Button onAction="#updateInvestment" text="Update" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
