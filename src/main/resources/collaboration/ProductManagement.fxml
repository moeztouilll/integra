<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a8.controllers.collaboration.ProductManagementController"
      spacing="20" styleClass="main-container">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Navigation Header -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: rgba(0, 5, 1, 0.95); -fx-padding: 15px 20px; -fx-border-color: rgba(247, 240, 245, 0.1); -fx-border-width: 0 0 1 0;">
        <Label text="🛍️ INVESTI - Products" style="-fx-text-fill: #F7F0F5; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🛍️ View Catalog" onAction="#handleViewCatalog" style="-fx-background-color: transparent; -fx-text-fill: #F7F0F5; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 8px 15px; -fx-background-radius: 6px;"/>
        <Button text="🏠 Home" onAction="#handleGoHome" style="-fx-background-color: transparent; -fx-text-fill: #F7F0F5; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 8px 15px; -fx-background-radius: 6px;"/>
        <Button text="⚙ Admin Dashboard" onAction="#handleGoAdminDashboard" style="-fx-background-color: transparent; -fx-text-fill: #F7F0F5; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 8px 15px; -fx-background-radius: 6px;"/>
    </HBox>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🛍️ Product Management" styleClass="page-title" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Add Product" onAction="#handleAddProduct" styleClass="btn-primary"/>
        <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- Search Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Search by name, category, or ID..." 
                   HBox.hgrow="ALWAYS" styleClass="search-field"/>
    </HBox>

    <!-- Product Table -->
    <TableView fx:id="productTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="150"/>
            <TableColumn fx:id="colPrice" text="Price" prefWidth="80"/>
            <TableColumn fx:id="colCurrency" text="Currency" prefWidth="80"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            <TableColumn fx:id="colStock" text="Stock" prefWidth="70"/>
            <TableColumn fx:id="colRemise" text="Remise (%)" prefWidth="80"/>
            <TableColumn fx:id="colViews" text="Views" prefWidth="70"/>
            <TableColumn fx:id="colSales" text="Sales" prefWidth="70"/>
        </columns>
    </TableView>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="✏️ Edit" onAction="#handleEditProduct" styleClass="btn-secondary"/>
        <Button text="🗑️ Delete" onAction="#handleDeleteProduct" styleClass="btn-danger"/>
    </HBox>

    <!-- Form Container (Hidden by default) -->
    <VBox fx:id="formContainer" spacing="15" styleClass="form-container" visible="false" managed="false"
          style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;">
        
        <Label text="Product Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="15" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="75"/>
            </columnConstraints>

            <!-- Row 0: Name -->
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="nameField" promptText="Product name" 
                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <!-- Row 1: Description -->
            <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextArea fx:id="descriptionField" promptText="Product description" 
                     prefRowCount="3" wrapText="true"
                     GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <!-- Row 2: Price & Currency -->
            <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <TextField fx:id="priceField" promptText="0.00" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="currencyCombo" prefWidth="100"/>
            </HBox>

            <!-- Row 3: Category & Status -->
            <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <ComboBox fx:id="categoryCombo" editable="true" promptText="Select or type category" 
                         HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="statusCombo" prefWidth="120"/>
            </HBox>

            <!-- Row 4: Stock & Discount -->
            <Label text="Stock:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
                <TextField fx:id="stockField" promptText="0" prefWidth="100"/>
                <Label text="Discount (%):"/>
                <TextField fx:id="remiseField" promptText="0" prefWidth="100"/>
            </HBox>

            <!-- Row 5: Digital Product -->
            <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <CheckBox fx:id="digitalCheckBox" text="Digital Product" 
                     GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <!-- Row 6: Image -->
            <Label text="Image:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <TextField fx:id="imageUrlField" promptText="Image URL or path" HBox.hgrow="ALWAYS"/>
                <Button text="📁 Browse" onAction="#handleBrowseImage"/>
            </HBox>
        </GridPane>

        <!-- Form Buttons -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="saveButton" text="Save" onAction="#handleSave" styleClass="btn-primary"/>
            <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        </HBox>
    </VBox>

</VBox>
