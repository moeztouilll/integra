<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.events.AddInscriptionController"
            stylesheets="@css/style.css"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <Label text="📝 Inscription" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label text="Ajouter ou modifier une inscription" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: white; -fx-max-width: 500;">

            <Label text="ID Utilisateur *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
            <ComboBox fx:id="cbUtilisateur" prefWidth="400" promptText="Sélectionnez un utilisateur"/>

            <Label text="Événement *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
            <ComboBox fx:id="cbEvenement" prefWidth="400" promptText="Sélectionnez un événement"/>

            <Label text="Statut *" style="-fx-font-weight: 600; -fx-text-fill: #334155;"/>
            <ComboBox fx:id="cbStatut" prefWidth="400"/>

            <Separator style="-fx-padding: 10 0;"/>

            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="btnAction" text="➕ Ajouter" onAction="#ajouterInscription"
                        styleClass="btn-primary" prefWidth="150"/>
                <Button fx:id="btnAnnuler" text="❌ Annuler" onAction="#annuler"
                        styleClass="btn-secondary" prefWidth="150"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
