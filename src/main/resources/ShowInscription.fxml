<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.events.ShowInscriptionController"
            stylesheets="@css/style.css">

    <!-- TITRE -->
    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #10B981; -fx-padding: 20;">
            <Label text="📋 LISTE DES INSCRIPTIONS"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </HBox>
    </top>


    <!-- TABLE -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Bouton Ajouter -->
            <HBox alignment="CENTER_RIGHT">
                <Button text="➕ Ajouter une inscription" onAction="#navAjout"
                        style="-fx-background-color: #10B981; -fx-text-fill: white;
                              -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-height: 40px;"/>
            </HBox>

            <!-- Table (sans colonne ID Inscription) -->
            <TableView fx:id="tabInscription" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIdUser" text="ID Utilisateur" prefWidth="150"/>
                    <TableColumn fx:id="colIdEvenement" text="ID Événement" prefWidth="150"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
                    <TableColumn fx:id="colDateInscription" text="Date Inscription" prefWidth="180"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
