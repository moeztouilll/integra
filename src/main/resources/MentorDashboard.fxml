<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.events.MentorDashboardController"
            stylesheets="@css/style.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-box">
                <Label text="👔 INVESTI" styleClass="header-title"/>
                <Label text="— Mentor Dashboard"
                       style="-fx-text-fill: #64748B; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🏠 Accueil" onAction="#navToHome" 
                        styleClass="modern-button, button-primary" style="-fx-padding: 8 16;"/>
                <Button text="🚪 Déconnexion" onAction="#handleLogout" 
                        styleClass="modern-button, button-danger" style="-fx-padding: 8 16;"/>
                <Button fx:id="btnToggleTheme" text="🌙 Mode Sombre" onAction="#toggleTheme" 
                        styleClass="modern-button, button-secondary" style="-fx-padding: 8 16;"/>
            </HBox>

            <HBox styleClass="nav-bar" spacing="0">
                <Button fx:id="btnNavEvenement" text="📅  MES ÉVÉNEMENTS"
                        onAction="#afficherEvenements" styleClass="nav-btn-active"/>
                <Button fx:id="btnNavInscription" text="📋  MES PARTICIPANTS"
                        onAction="#afficherInscriptions" styleClass="nav-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane">

            <!-- VUE MENTOR ÉVÉNEMENTS -->
            <VBox fx:id="vueEvenements" spacing="15" styleClass="event-view-container" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT" VBox.vgrow="NEVER">
                    <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="SOMETIMES" maxWidth="600">
                        <TextField fx:id="searchEvenement" promptText="🔍 Rechercher..."
                                   styleClass="search-box" onKeyReleased="#rechercherEvenements"
                                   maxWidth="200" minWidth="100"/>
                        <ComboBox fx:id="filtreLieuEvent" promptText="Lieu" styleClass="filter-combo" 
                                   onAction="#filtrerEvenements" maxWidth="120" prefWidth="120"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCountEvent" text="0 événement(s)" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" minWidth="100"/>
                    <HBox spacing="8" alignment="CENTER_RIGHT">
                        <Button text="📥 CSV" styleClass="btn-export" onAction="#exporterEvenementsCSV"/>
                        <Button text="📄 PDF" styleClass="btn-export" onAction="#exporterEvenementsPDF"/>
                        <Button text="➕ Créer" styleClass="btn-success" onAction="#navAjoutEvenement" style="-fx-padding: 8 12;"/>
                    </HBox>
                </HBox>

                <TableView fx:id="tabEvenement" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colEventId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colEventImage" text="Image" prefWidth="100"/>
                        <TableColumn fx:id="colEventTitre" text="Titre" prefWidth="150"/>
                        <TableColumn fx:id="colEventLieu" text="Lieu" prefWidth="120"/>
                        <TableColumn fx:id="colEventDateDebut" text="Date Début" prefWidth="150"/>
                        <TableColumn fx:id="colEventDateFin" text="Date Fin" prefWidth="150"/>
                        <TableColumn fx:id="colEventActions" text="Actions" prefWidth="180"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- VUE MENTOR INSCRIPTIONS -->
            <VBox fx:id="vueInscriptions" spacing="15" styleClass="event-view-container" style="-fx-padding: 20;" visible="false" managed="false">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchInscription" promptText="🔍 Rechercher participant..."
                               styleClass="search-box" onKeyReleased="#rechercherInscriptions"
                               maxWidth="250"/>
                    <ComboBox fx:id="filtreStatutInscr" promptText="Statut" styleClass="filter-combo"
                              onAction="#filtrerInscriptions"/>
                    <ComboBox fx:id="filtreEventInscr" promptText="Mon Événement" styleClass="filter-combo"
                              onAction="#filtrerInscriptions"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCountInscr" text="0 participant(s)" style="-fx-text-fill: #64748B;"/>
                    <Button text="📥 CSV" styleClass="btn-export" onAction="#exporterInscriptionsCSV"/>
                    <Button text="📄 PDF" styleClass="btn-export" onAction="#exporterInscriptionsPDF"/>
                    <Button text="➕ Ajouter" styleClass="btn-success" onAction="#navAjoutInscription" style="-fx-padding: 8 12;"/>
                </HBox>

                <TableView fx:id="tabInscription" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colInscrId" text="ID Inscription" prefWidth="90" sortable="true"/>
                        <TableColumn fx:id="colInscrUser" text="Participant" prefWidth="150" sortable="true"/>
                        <TableColumn fx:id="colInscrEvent" text="Événement" prefWidth="150" sortable="true"/>
                        <TableColumn fx:id="colInscrStatut" text="Statut" prefWidth="110" sortable="true"/>
                        <TableColumn fx:id="colInscrDate" text="Date d'Inscription" prefWidth="160" sortable="true"/>
                        <TableColumn fx:id="colInscrActions" text="Actions" prefWidth="180"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
