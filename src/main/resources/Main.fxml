<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a8.controllers.events.MainController"
            stylesheets="@css/style.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-box">
                <Label text="⚡ INVESTI" styleClass="header-title"/>
                <Label text="— Plateforme de Gestion"
                       style="-fx-text-fill: #64748B; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🏠 Admin Dashboard" onAction="#backToAdminDashboard"
                        styleClass="modern-button, button-secondary" style="-fx-padding: 8 16;"/>
                <Button fx:id="btnToggleTheme" text="🌙 Mode Sombre" onAction="#toggleTheme" 
                        styleClass="modern-button, button-secondary" style="-fx-padding: 8 16;"/>
                <Label fx:id="lblDateTime" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
            </HBox>

            <HBox styleClass="nav-bar" spacing="0">
                <Button fx:id="btnNavEvenement" text="📅  ÉVÉNEMENTS"
                        onAction="#afficherEvenements" styleClass="nav-btn-active"/>
                <Button fx:id="btnNavInscription" text="📋  INSCRIPTIONS"
                        onAction="#afficherInscriptions" styleClass="nav-btn"/>
                <Button fx:id="btnNavStats" text="📊  STATISTIQUES"
                        onAction="#afficherStats" styleClass="nav-btn"/>
                <Button fx:id="btnNavCalendrier" text="📆  CALENDRIER"
                        onAction="#afficherCalendrier" styleClass="nav-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #F5F7FA;">

            <!-- VUE ÉVÉNEMENTS -->
            <VBox fx:id="vueEvenements" spacing="15" style="-fx-padding: 20;">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchEvenement" promptText="🔍 Rechercher..."
                               styleClass="search-box" onKeyReleased="#rechercherEvenements"/>
                    <ComboBox fx:id="filtreLieuEvent" promptText="Lieu" styleClass="filter-combo"
                              onAction="#filtrerEvenements"/>
                    <ComboBox fx:id="filtreMentorEvent" promptText="Mentor" styleClass="filter-combo"
                              onAction="#filtrerEvenements"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCountEvent" text="0 événement(s)" style="-fx-text-fill: #64748B;"/>
                    <Button text="📥 Export CSV" styleClass="btn-export" onAction="#exporterEvenementsCSV"/>
                    <Button text="➕ Ajouter" styleClass="btn-success" onAction="#navAjoutEvenement"/>
                </HBox>

                <TableView fx:id="tabEvent" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colEventId" text="ID" prefWidth="50" sortable="true"/>
                        <TableColumn fx:id="colEventImage" text="Image" prefWidth="80" sortable="false"/>
                        <TableColumn fx:id="colEventMentor" text="Mentor" prefWidth="80" sortable="true"/>
                        <TableColumn fx:id="colEventTitre" text="Titre" prefWidth="150" sortable="true"/>
                        <TableColumn fx:id="colEventLieu" text="Lieu" prefWidth="120" sortable="true"/>
                        <TableColumn fx:id="colEventDebut" text="Début" prefWidth="130" sortable="true"/>
                        <TableColumn fx:id="colEventFin" text="Fin" prefWidth="130" sortable="true"/>
                        <TableColumn fx:id="colEventActions" text="Actions" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- VUE INSCRIPTIONS -->
            <VBox fx:id="vueInscriptions" spacing="15" style="-fx-padding: 20;"
                  visible="false" managed="false">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchInscription" promptText="🔍 Rechercher..."
                               styleClass="search-box" onKeyReleased="#rechercherInscriptions"/>
                    <ComboBox fx:id="filtreStatutInscr" promptText="Statut" styleClass="filter-combo"
                              onAction="#filtrerInscriptions"/>
                    <ComboBox fx:id="filtreEventInscr" promptText="Événement" styleClass="filter-combo"
                              onAction="#filtrerInscriptions"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblCountInscr" text="0 inscription(s)" style="-fx-text-fill: #64748B;"/>
                    <Button text="📥 Export CSV" styleClass="btn-export" onAction="#exporterInscriptionsCSV"/>
                    <Button text="➕ Ajouter" styleClass="btn-success" onAction="#navAjoutInscription"/>
                </HBox>

                <TableView fx:id="tabInscription" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colInscrId" text="ID" prefWidth="60" sortable="true"/>
                        <TableColumn fx:id="colInscrUser" text="Utilisateur" prefWidth="120" sortable="true"/>
                        <TableColumn fx:id="colInscrEvent" text="Événement" prefWidth="120" sortable="true"/>
                        <TableColumn fx:id="colInscrStatut" text="Statut" prefWidth="110" sortable="true"/>
                        <TableColumn fx:id="colInscrDate" text="Date" prefWidth="160" sortable="true"/>
                        <TableColumn fx:id="colInscrActions" text="Actions" prefWidth="180"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- VUE STATISTIQUES -->
            <VBox fx:id="vueStats" spacing="20" style="-fx-padding: 20;"
                  visible="false" managed="false">
                <Label text="📊 Tableau de Bord" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

                <GridPane hgap="15" vgap="15">
                    <VBox styleClass="stat-card-blue" spacing="8" GridPane.columnIndex="0">
                        <Label text="ÉVÉNEMENTS" styleClass="label-stats"/>
                        <Label fx:id="lblStatEvents" text="0" styleClass="label-count"
                               style="-fx-text-fill: #1E40AF;"/>
                        <Label text="événements actifs" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox styleClass="stat-card-green" spacing="8" GridPane.columnIndex="1">
                        <Label text="INSCRIPTIONS" styleClass="label-stats"/>
                        <Label fx:id="lblStatInscr" text="0" styleClass="label-count"
                               style="-fx-text-fill: #15803D;"/>
                        <Label text="inscriptions totales" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox styleClass="stat-card-green" spacing="8" GridPane.columnIndex="2">
                        <Label text="CONFIRMÉES" styleClass="label-stats"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblStatConfirm" text="0" styleClass="label-count"
                                   style="-fx-text-fill: #15803D;"/>
                            <Label fx:id="lblPctConfirme" text="0%" styleClass="percentage-label"
                                   style="-fx-font-size: 18px; -fx-text-fill: #15803D;"/>
                        </HBox>
                        <Label text="statut confirmé" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox styleClass="stat-card-yellow" spacing="8" GridPane.columnIndex="3">
                        <Label text="EN ATTENTE" styleClass="label-stats"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblStatAttente" text="0" styleClass="label-count"
                                   style="-fx-text-fill: #CA8A04;"/>
                            <Label fx:id="lblPctAttente" text="0%" styleClass="percentage-label"
                                   style="-fx-font-size: 18px; -fx-text-fill: #CA8A04;"/>
                        </HBox>
                        <Label text="en attente" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                    </VBox>
                </GridPane>

                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20;
                                               -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                                               -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                        <Label text="Répartition par Statut" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                        <PieChart fx:id="chartStatut" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20;
                                               -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                                               -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                        <Label text="Événements par Mois" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                        <BarChart fx:id="chartEvents" VBox.vgrow="ALWAYS">
                            <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                            <yAxis><NumberAxis side="LEFT"/></yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
            </VBox>

            <!-- VUE CALENDRIER -->
            <VBox fx:id="vueCalendrier" spacing="20" style="-fx-padding: 20;"
                  visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="📆 Calendrier des Événements"
                           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="◀" onAction="#moisPrecedent" styleClass="btn-secondary"/>
                    <Label fx:id="lblMoisAnnee" text="Février 2026"
                           style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-min-width: 150; -fx-alignment: center;"/>
                    <Button text="▶" onAction="#moisSuivant" styleClass="btn-secondary"/>
                </HBox>

                <HBox spacing="15" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="gridCalendrier" hgap="5" vgap="5"
                              style="-fx-background-color: white; -fx-padding: 15;
                                     -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                                     -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                    </GridPane>

                    <VBox prefWidth="350" spacing="15" style="-fx-background-color: white; -fx-padding: 15;
                                                            -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                                                            -fx-background-radius: 8;">
                        <Label text="ℹ Détails de la journée" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E40AF;"/>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;" VBox.vgrow="ALWAYS">
                            <VBox fx:id="vboxEventDetails" spacing="12">
                                <Label text="Sélectionnez un jour avec ✓ pour voir les détails" style="-fx-text-fill: #64748B; -fx-font-style: italic;"/>
                            </VBox>
                        </ScrollPane>
                    </VBox>
                </HBox>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #FEE2E2; -fx-pref-width: 20; -fx-pref-height: 20;
                                      -fx-border-color: #A62639; -fx-border-width: 2;"/>
                        <Label text="Urgent (≤7 jours)" style="-fx-text-fill: #64748B;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #FEF3C7; -fx-pref-width: 20; -fx-pref-height: 20;
                                      -fx-border-color: #9B7E46; -fx-border-width: 2;"/>
                        <Label text="Bientôt (≤30 jours)" style="-fx-text-fill: #64748B;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #DBEAFE; -fx-pref-width: 20; -fx-pref-height: 20;
                                      -fx-border-color: #60A5FA; -fx-border-width: 2;"/>
                        <Label text="Avec événement(s)" style="-fx-text-fill: #64748B;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label style="-fx-background-color: #F8FAFC; -fx-pref-width: 20; -fx-pref-height: 20;
                                      -fx-border-color: #E2E8F0;"/>
                        <Label text="Sans événement" style="-fx-text-fill: #64748B;"/>
                    </HBox>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
