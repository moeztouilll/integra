<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a8.controllers.events.ShowEvenementController" stylesheets="@css/style.css">

    <!-- TITRE -->
    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #1E3A8A; -fx-padding: 20;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="📋 LISTE DES ÉVÉNEMENTS" />
        </HBox>
    </top>

    <!-- TABLE -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#navAjout" style="-fx-background-color: #10B981; -fx-text-fill: white;                               -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-height: 40px;" text="➕ Ajouter un événement" />
            </HBox>

            <TableView fx:id="tabEvent" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="id_mentorCol" prefWidth="80" text="ID Mentor" />
                    <TableColumn fx:id="titreCol" prefWidth="150" text="Titre" />
                    <TableColumn fx:id="contenuCol" prefWidth="200" text="Contenu" />
                    <TableColumn fx:id="lieuCol" prefWidth="120" text="Lieu" />
                    <TableColumn fx:id="debCol" prefWidth="150" text="Date Début" />
                    <TableColumn fx:id="finCol" prefWidth="150" text="Date Fin" />
                    <TableColumn fx:id="actCol" prefWidth="200" text="Actions" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
